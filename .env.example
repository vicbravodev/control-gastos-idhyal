APP_NAME=Laravel
# Also passed into the Sail container (compose.yaml) so the entrypoint can run composer / npm when vendor or Vite output is missing (e.g. Dokploy bind mount).
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Reverse proxy (Dokploy, nginx, Traefik, Cloudflare): trust X-Forwarded-* from this hop. Default "*" in config/trustedproxy.php.
# TRUSTED_PROXIES=*

# Docker Compose / Sail image build: numeric GID/UID for the `sail` user (must match host for volume perms).
# If unset, compose.yaml defaults to 1000 / 1337 so `docker compose build` works in CI without a .env.
WWWGROUP=1000
WWWUSER=1337

# Host port mapped to the app container (:80 inside). Default 80. If the host already uses 80 (e.g. Dokploy/Traefik
# or nginx), set a free port here (e.g. 8080) or adjust routing in the panel so the proxy targets the service:80 on the Docker network.
# APP_PORT=8080
# VITE_PORT=5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue: notifications implement ShouldQueue and are dispatched to this connection.
# With redis (default here), you must run a worker or emails never leave the queue (empty Mailpit).
#   composer run dev  → includes php artisan horizon
#   php artisan horizon
#   php artisan queue:work redis
# Troubleshooting: Horizon at /horizon (pending and failed jobs), or php artisan queue:failed.
# Local without Redis: set QUEUE_CONNECTION=sync to send mail immediately (not for production).
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: match how PHP reaches your SMTP capture (e.g. Mailpit).
# - PHP inside Laravel Sail / same Docker network as Mailpit:
#     MAIL_MAILER=smtp, MAIL_HOST=mailpit, MAIL_PORT=1025
# - PHP on the host, Mailpit container with published SMTP port (often 1025):
#     MAIL_MAILER=smtp, MAIL_HOST=127.0.0.1, MAIL_PORT=1025 (use the mapped host port)
# - No SMTP needed: MAIL_MAILER=log writes to the log instead of sending.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
